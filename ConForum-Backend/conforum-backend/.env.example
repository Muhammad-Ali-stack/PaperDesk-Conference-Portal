# ─────────────────────────────────────────────────────────────────────────────
# ConForum Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

PORT=5000
BASE_URL=https://your-domain.com


# ── JWT ───────────────────────────────────────────────────────────────────────

JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars


# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: app.supabase.com → Project Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_API_KEY=your_supabase_anon_or_service_role_key


# ── IEEE Checker Microservice ─────────────────────────────────────────────────
# Internal URL of the Flask service (no trailing slash)

IEEE_CHECKER_URL=http://localhost:6000


# ── Gmail SMTP — Email Accounts ───────────────────────────────────────────────
#
# Each account requires:
#   1. A dedicated Gmail address
#   2. A Gmail App Password (NOT the account password)
#
# How to generate an App Password:
#   a. Go to myaccount.google.com → Security
#   b. Enable 2-Step Verification
#   c. Search "App passwords" → create one for "Mail"
#   d. Paste the 16-character code below (spaces are optional)
#
# Account purposes:
#   ORGANIZER  — conference approval / rejection notices to organizers
#   REVIEWER   — paper status emails (accepted, rejected) sent to authors
#   INVITATION — token-based reviewer / organizer invitation links
#   OTP        — one-time passwords for login (HIGH PRIORITY)
#   FALLBACK   — catch-all when a specific transporter is unavailable

GMAIL_ORGANIZER_USER=conforum.organizer@gmail.com
GMAIL_ORGANIZER_PASS=xxxx xxxx xxxx xxxx

GMAIL_REVIEWER_USER=conforum.reviewer@gmail.com
GMAIL_REVIEWER_PASS=xxxx xxxx xxxx xxxx

GMAIL_INVITATION_USER=conforum.invitation@gmail.com
GMAIL_INVITATION_PASS=xxxx xxxx xxxx xxxx

GMAIL_OTP_USER=conforum.otp@gmail.com
GMAIL_OTP_PASS=xxxx xxxx xxxx xxxx

GMAIL_FALLBACK_USER=conforum.fallback@gmail.com
GMAIL_FALLBACK_PASS=xxxx xxxx xxxx xxxx
