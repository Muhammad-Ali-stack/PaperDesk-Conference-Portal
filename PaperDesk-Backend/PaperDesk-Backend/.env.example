# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_anon_or_service_key

# Base URLs
ORGANIZER_INVITE_URL=http://localhost:4000
BASE_URL=http://localhost:4000

# Gmail / Nodemailer credentials (use App Passwords)
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password

# Separate accounts for different roles (optional – can reuse same email)
GMAIL_ORGANIZER_USER=organizer_email@gmail.com
GMAIL_ORGANIZER_PASS=organizer_app_password

GMAIL_REVIEWER_USER=reviewer_email@gmail.com
GMAIL_REVIEWER_PASS=reviewer_app_password

GMAIL_INVITATION_USER=invitation_email@gmail.com
GMAIL_INVITATION_PASS=invitation_app_password

GMAIL_OTP_USER=otp_email@gmail.com
GMAIL_OTP_PASS=otp_app_password

GMAIL_FALLBACK_USER=fallback_email@gmail.com
GMAIL_FALLBACK_PASS=fallback_app_password